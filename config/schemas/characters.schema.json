{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michael-freling/anime-metadata-db/config/schemas/characters.schema.json",
  "title": "Anime characters & staff record (R2)",
  "description": "Schema for authored config/overrides/characters/ and generated data/characters/ files.",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "characters": { "type": "array", "items": { "$ref": "#/$defs/character" } },
    "staff": { "type": "array", "items": { "$ref": "#/$defs/staff" } }
  },
  "anyOf": [
    { "required": ["characters"] },
    { "required": ["staff"] }
  ],
  "$defs": {
    "id": { "type": "string", "minLength": 1 },
    "names": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "original": { "type": "string" },
        "translations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "externalIds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anilistId": { "type": "integer" },
        "anidbId": { "type": "integer" },
        "tmdbId": { "type": "integer" },
        "tvdbId": { "type": "integer" },
        "wikidataId": { "type": "string", "pattern": "^Q[0-9]+$" }
      }
    },
    "voiceActor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["staffId", "language"],
      "properties": {
        "staffId": { "$ref": "#/$defs/id" },
        "language": { "type": "string", "minLength": 1 }
      }
    },
    "scopeRef": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "seasonId": { "$ref": "#/$defs/id" },
        "movieId": { "$ref": "#/$defs/id" },
        "specialId": { "$ref": "#/$defs/id" }
      }
    },
    "appearance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seriesId"],
      "properties": {
        "seriesId": { "$ref": "#/$defs/id" },
        "scope": { "type": "array", "items": { "$ref": "#/$defs/scopeRef" } },
        "voiceActors": { "type": "array", "items": { "$ref": "#/$defs/voiceActor" } },
        "externalIds": { "$ref": "#/$defs/externalIds" }
      }
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "names": { "$ref": "#/$defs/names" },
        "externalIds": { "$ref": "#/$defs/externalIds" },
        "voiceActors": { "type": "array", "items": { "$ref": "#/$defs/voiceActor" } },
        "appearances": { "type": "array", "items": { "$ref": "#/$defs/appearance" } }
      }
    },
    "staff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "names": { "$ref": "#/$defs/names" },
        "externalIds": { "$ref": "#/$defs/externalIds" }
      }
    }
  }
}
